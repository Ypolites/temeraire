generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────
// ENUMS
// ───────────────────────────────────────────

enum MoodCategory {
  NEUTRAL
  HAPPY
  SAD
  ANGRY
  SCARED
  DETERMINED
}

enum DocumentCategory {
  LORE
  RULES
  MAP
  OTHER
}

enum SpeciesCategory {
  HUMAN
  DRAGON
}

enum PronounsCategory {
  HE_HIM
  SHE_HER
  THEY_THEM
}

enum LevelsCategory {
  NOVICE
  APPRENTICE
  JOURNEYMAN
  EXPERT
  MASTER
}

enum DangerTypeCategory {
  WOUND
  EXHAUSTION
  FEAR
}

enum DevotionCategory {
  FAITH
  LOYALTY
  AMBITION
}

// ───────────────────────────────────────────
// MODELS
// ───────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  username     String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  ownedSessions    GameSession[]    @relation("SessionOwner")
  sessionPlayers   SessionPlayer[]
  messages         Message[]
  libraryDocuments LibraryDocument[]
  characters       Character[]

  @@map("users")
}

model GameSession {
  id          String   @id @default(uuid())
  ownerUserId String   @map("owner_user_id")
  name        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner            User              @relation("SessionOwner", fields: [ownerUserId], references: [id])
  sessionPlayers   SessionPlayer[]
  messages         Message[]
  libraryDocuments LibraryDocument[]
  characters       Character[]

  @@map("game_session")
}

model SessionPlayer {
  id            String @id @default(uuid())
  gameSessionId String @map("game_session_id")
  userId        String @map("user_id")

  gameSession GameSession @relation(fields: [gameSessionId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@unique([gameSessionId, userId])
  @@map("session_player")
}

model Message {
  id            String        @id @default(uuid())
  gameSessionId String        @map("game_session_id")
  isGmMessage   Boolean       @default(false) @map("is_gm_message")
  authorUserId  String?       @map("author_user_id")
  content       String
  caption       String?
  selectedMood  MoodCategory? @map("selected_mood")
  createdAt     DateTime      @default(now()) @map("created_at")

  gameSession GameSession @relation(fields: [gameSessionId], references: [id])
  author      User?       @relation(fields: [authorUserId], references: [id])

  @@map("messages")
}

model LibraryDocument {
  id              String           @id @default(uuid())
  gameSessionId   String           @map("game_session_id")
  createdByUserId String           @map("created_by_user_id")
  category        DocumentCategory
  title           String
  fileType        String           @default("PDF") @map("file_type")
  fileUrl         String           @map("file_url")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  gameSession   GameSession @relation(fields: [gameSessionId], references: [id])
  createdByUser User        @relation(fields: [createdByUserId], references: [id])

  @@map("library_documents")
}

model Character {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  gameSessionId String           @map("game_session_id")
  species       SpeciesCategory
  name          String
  pronouns      PronounsCategory
  appearance    String?
  position      String
  nationality   String?
  serviceRecord String?          @map("service_record")
  station       String?
  temperament   String?
  distinctions  String?
  attrBody      Int              @default(0) @map("attr_body")
  attrCunning   Int              @default(0) @map("attr_cunning")
  attrManners   Int              @default(0) @map("attr_manners")
  attrSteel     Int              @default(0) @map("attr_steel")
  burdenDuty    Int              @default(0) @map("burden_duty")
  burdenDesire  Int              @default(0) @map("burden_desire")
  connections   String?
  bonds         String?
  traits        String?
  abilities     String?
  equipment     String?

  user        User        @relation(fields: [userId], references: [id])
  gameSession GameSession @relation(fields: [gameSessionId], references: [id])

  resources         CharacterResource[]
  areasOfExpertise  CharacterAreaOfExpertise[]
  dangers           CharacterDanger[]
  devotions         CharacterDevotion[]
  skills            CharacterSkill[]
  avatarsMood       AvatarMood[]

  @@map("characters")
}

model Resource {
  id          String  @id @default(uuid())
  name        String
  description String?

  characterResources CharacterResource[]

  @@map("resources")
}

model CharacterResource {
  id          String @id @default(uuid())
  characterId String @map("character_id")
  resourceId  String @map("resource_id")
  uses        Int    @default(0)
  quantity    Int    @default(1)

  character Character @relation(fields: [characterId], references: [id])
  resource  Resource  @relation(fields: [resourceId], references: [id])

  @@unique([characterId, resourceId])
  @@map("character_resources")
}

model AreaOfExpertise {
  id    String         @id @default(uuid())
  name  String
  level LevelsCategory

  characterAreasOfExpertise CharacterAreaOfExpertise[]

  @@map("areas_of_expertise")
}

model CharacterAreaOfExpertise {
  id                String @id @default(uuid())
  characterId       String @map("character_id")
  areaOfExpertiseId String @map("area_of_expertise_id")

  character       Character       @relation(fields: [characterId], references: [id])
  areaOfExpertise AreaOfExpertise @relation(fields: [areaOfExpertiseId], references: [id])

  @@unique([characterId, areaOfExpertiseId])
  @@map("character_areas_of_expertise")
}

model CharacterDanger {
  id           String             @id @default(uuid())
  characterId  String             @map("character_id")
  dangerType   DangerTypeCategory @map("danger_type")
  level        Int                @default(0)
  trackSize    Int                @default(3) @map("track_size")
  trackCounter Int                @default(0) @map("track_counter")

  character Character @relation(fields: [characterId], references: [id])

  @@unique([characterId, dangerType])
  @@map("character_dangers")
}

model Devotion {
  id           String           @id @default(uuid())
  devotionType DevotionCategory @map("devotion_type")
  name         String
  description  String?
  rank         Int
  trackCounter Int              @default(0) @map("track_counter")

  characterDevotions CharacterDevotion[]

  @@map("devotions")
}

model CharacterDevotion {
  id          String  @id @default(uuid())
  characterId String  @map("character_id")
  devotionId  String  @map("devotion_id")
  isDenied    Boolean @default(false) @map("is_denied")

  character Character @relation(fields: [characterId], references: [id])
  devotion  Devotion  @relation(fields: [devotionId], references: [id])

  @@unique([characterId, devotionId])
  @@map("character_devotions")
}

model CharacterSkill {
  id            String  @id @default(uuid())
  characterId   String  @map("character_id")
  attributeName String  @map("attribute_name")
  skillName     String  @map("skill_name")
  level         String?

  character Character @relation(fields: [characterId], references: [id])

  @@unique([characterId, skillName])
  @@map("character_skills")
}

model AvatarMood {
  id          String        @id @default(uuid())
  characterId String        @map("character_id")
  moodLabel   MoodCategory? @map("mood_label")
  imageUrl    String?       @map("image_url")

  character Character @relation(fields: [characterId], references: [id])

  @@map("avatars_mood")
}