generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username         String            @db.VarChar
  email            String            @unique @db.VarChar
  passwordHash     String            @map("password_hash") @db.VarChar
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  characters       Character[]
  ownedSessions    GameSession[]     @relation("SessionOwner")
  libraryDocuments LibraryDocument[]
  messages         Message[]
  sessionPlayers   SessionPlayer[]

  @@map("users")
}

model GameSession {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId      String            @map("owner_user_id") @db.Uuid
  name             String            @db.VarChar
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  characters       Character[]
  owner            User              @relation("SessionOwner", fields: [ownerUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  libraryDocuments LibraryDocument[]
  messages         Message[]
  sessionPlayers   SessionPlayer[]

  @@map("game_session")
}

model SessionPlayer {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gameSessionId String      @map("game_session_id") @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user          User        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([gameSessionId, userId], map: "session_player_game_session_id_user_id_idx")
  @@map("session_player")
}

model Message {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gameSessionId String         @map("game_session_id") @db.Uuid
  isGmMessage   Boolean        @default(false) @map("is_gm_message")
  authorUserId  String?        @map("author_user_id") @db.Uuid
  content       String
  caption       String?
  selectedMood  mood_category? @map("selected_mood")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  author        User?          @relation(fields: [authorUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  gameSession   GameSession    @relation(fields: [gameSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("messages")
}

model LibraryDocument {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gameSessionId   String            @map("game_session_id") @db.Uuid
  createdByUserId String            @map("created_by_user_id") @db.Uuid
  category        document_category
  title           String            @db.VarChar
  fileType        String            @default("PDF") @map("file_type") @db.VarChar
  fileUrl         String            @map("file_url") @db.VarChar
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  createdByUser   User              @relation(fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  gameSession     GameSession       @relation(fields: [gameSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("library_documents")
}

model Character {
  id               String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String                     @map("user_id") @db.Uuid
  gameSessionId    String                     @map("game_session_id") @db.Uuid
  species          species_category
  name             String                     @db.VarChar
  pronouns         pronouns_category
  appearance       String?
  position         String                     @db.VarChar
  nationality      String?                    @db.VarChar
  serviceRecord    String?                    @map("service_record") @db.VarChar
  station          String?                    @db.VarChar
  temperament      String?                    @db.VarChar
  distinctions     String?
  attrBody         Int                        @default(0) @map("attr_body")
  attrCunning      Int                        @default(0) @map("attr_cunning")
  attrManners      Int                        @default(0) @map("attr_manners")
  attrSteel        Int                        @default(0) @map("attr_steel")
  burdenDuty       Int                        @default(0) @map("burden_duty")
  burdenDesire     Int                        @default(0) @map("burden_desire")
  connections      String?
  bonds            String?
  traits           String?
  abilities        String?
  equipment        String?
  avatarsMood      AvatarMood[]
  areasOfExpertise CharacterAreaOfExpertise[]
  dangers          CharacterDanger[]
  devotions        CharacterDevotion[]
  resources        CharacterResource[]
  skills           CharacterSkill[]
  gameSession      GameSession                @relation(fields: [gameSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user             User                       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("characters")
}

model Resource {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String              @db.VarChar
  description        String?
  characterResources CharacterResource[]

  @@map("resources")
}

model CharacterResource {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  characterId String    @map("character_id") @db.Uuid
  resourceId  String    @map("resource_id") @db.Uuid
  uses        Int       @default(0)
  quantity    Int       @default(1)
  character   Character @relation(fields: [characterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resource    Resource  @relation(fields: [resourceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([characterId, resourceId], map: "character_resources_character_id_resource_id_idx")
  @@map("character_resources")
}

model AreaOfExpertise {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String                     @db.VarChar
  level                     levels_category
  characterAreasOfExpertise CharacterAreaOfExpertise[]

  @@map("areas_of_expertise")
}

model CharacterAreaOfExpertise {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  characterId       String          @map("character_id") @db.Uuid
  areaOfExpertiseId String          @map("area_of_expertise_id") @db.Uuid
  areaOfExpertise   AreaOfExpertise @relation(fields: [areaOfExpertiseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  character         Character       @relation(fields: [characterId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([characterId, areaOfExpertiseId], map: "character_areas_of_expertise_character_id_area_of_expertise_idx")
  @@map("character_areas_of_expertise")
}

model CharacterDanger {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  characterId  String               @map("character_id") @db.Uuid
  dangerType   danger_type_category @map("danger_type")
  level        Int                  @default(0)
  trackSize    Int                  @default(3) @map("track_size")
  trackCounter Int                  @default(0) @map("track_counter")
  character    Character            @relation(fields: [characterId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([characterId, dangerType], map: "character_dangers_character_id_danger_type_idx")
  @@map("character_dangers")
}

model Devotion {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  devotionType       devotion_category   @map("devotion_type")
  name               String              @db.VarChar
  description        String?
  rank               Int
  trackCounter       Int                 @default(0) @map("track_counter")
  characterDevotions CharacterDevotion[]

  @@map("devotions")
}

model CharacterDevotion {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  characterId String    @map("character_id") @db.Uuid
  devotionId  String    @map("devotion_id") @db.Uuid
  isDenied    Boolean   @default(false) @map("is_denied")
  character   Character @relation(fields: [characterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  devotion    Devotion  @relation(fields: [devotionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([characterId, devotionId], map: "character_devotions_character_id_devotion_id_idx")
  @@map("character_devotions")
}

model CharacterSkill {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  characterId   String    @map("character_id") @db.Uuid
  attributeName String    @map("attribute_name") @db.VarChar
  skillName     String    @map("skill_name") @db.VarChar
  level         String?   @db.VarChar
  character     Character @relation(fields: [characterId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([characterId, skillName], map: "character_skills_character_id_skill_name_idx")
  @@map("character_skills")
}

model AvatarMood {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  characterId String         @map("character_id") @db.Uuid
  moodLabel   mood_category? @map("mood_label")
  imageUrl    String?        @map("image_url") @db.VarChar
  character   Character      @relation(fields: [characterId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("avatars_mood")
}

enum danger_type_category {
  dishonor
  scandal
  stress
  wounds
}

enum devotion_category {
  duty
  desire
}

enum document_category {
  R_gles        @map("Règles")
  Directives_MJ @map("Directives MJ")
  Campagne
  Lore
}

enum levels_category {
  Casual
  Veteran
  Esoteric
}

enum mood_category {
  neutral
  happy
  sad
  angry
  scared
  surprised
  determined
  hurt
  mocking
  focus
}

enum pronouns_category {
  He_him    @map("He/him")
  She_her   @map("She/her")
  They_them @map("They/them")
}

enum species_category {
  Human
  Dragon
}
