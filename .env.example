# Base de données
PORT=3000
DATABASE_URL="postgresql://postgres:motdepasse@localhost:5432/temeraire_db"

# Authentification
# ⚠️ Remplace par une vraie valeur longue et secrète en local / prod.
JWT_SECRET="change-me-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# LLM — changer la valeur pour switcher de provider
# Provider possible : "mock", "claude", etc.
LLM_PROVIDER="mock"
ANTHROPIC_API_KEY="sk-ant-api-XXXXXXXXXXXXXXXXXXXXXXXX"
OPENAI_API_KEY=""
LLM_MODEL="claude-haiku-4-5"

# Dés — changer la valeur pour switcher de provider
DICE_PROVIDER="local"

